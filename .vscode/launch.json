            "env": {
                "CUDA_VISIBLE_DEVICES": "0"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "type": "meta-python",
            "request": "launch",
            "name": "Gemma 4 Object Detection",
            "program": "${workspaceFolder}/gemma4/detect_objects.py",
            "args": [
